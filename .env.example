# Vercel cron auth — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Web push (reuse Inbox VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@chatiq.io
