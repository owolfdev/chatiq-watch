# Supabase (same project as chatiq)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Watch app URL (local or production)
NEXT_PUBLIC_WATCH_URL=http://localhost:3002

# Smoke runner target + credentials
MAIN_APP_URL=https://www.chatiq.io
WATCH_SMOKE_API_KEY=
